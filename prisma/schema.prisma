generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    Int            @id @default(autoincrement())
  username              String         @unique
  password              String
  perms                 Int
  report_notifications  Boolean        @default(true)
  vaccine_notifications Boolean        @default(true)
  notifications         Notification[]
}

model Animal {
  id                  Int       @id @default(autoincrement())
  nome                String?
  chip                String?   @unique
  sex                 Int?
  image               String?
  raca                String?
  porte               Int?      @db.SmallInt
  altura              Int?
  peso                Float?
  esterelizacao       Int?      @db.SmallInt
  observacoes         String?
  data_ultima_vacina  DateTime? @map("data_ultima_vacina")
  data_proxima_vacina DateTime? @map("data_proxima_vacina")
  arquivos             String?
}

model Stocks {
  id         Int      @id @default(autoincrement())
  nome       String
  quantidade Int
  datas      DateTime @default(now())
  utilizador Int
}

model StockHistory {
  id         Int      @id @default(autoincrement())
  stockId    Int
  nome       String
  quantidade Int
  datas      DateTime @default(now())
  utilizador Int
}

model Colonia {
  id          Int    @id @default(autoincrement())
  nome        String
  responsavel String
  contacto    String
  num_animais Int
  longitude   Float
  latitude    Float
}

model Ocorrencia {
  id             Int       @id @default(autoincrement())
  titulo         String
  descricao      String
  morada         String
  latitude       Float?
  longitude      Float?
  data_criacao   DateTime
  data_resolucao DateTime?
  estado         Int
}

model Notification {
  id          Int      @id @default(autoincrement())
  type        String
  title       String
  description String
  dataAndTime DateTime
  read        Boolean  @default(false)
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
}

model AnimalHistory {
  id         BigInt   @id @default(autoincrement())
  created_at DateTime @default(now()) @db.Timestamptz(6)
  titulo     String?
  ficheiro   String?
  animalid   BigInt?
}
